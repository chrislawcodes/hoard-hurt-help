+<div id="reconnect" class="card bot-reconnect">
+    <h3 style="margin-top:0;">⚠ Connection not ready</h3>
+    <p class="hint">
+        {% if health.state.value == 'stalled' and health.game_name %}
+            This connection has an agent in <strong>{{ health.game_name }}</strong> right now, but the runner isn't keeping up.
+        {% elif health.never_connected %}
+            This connection has never connected, so it can't play yet.
+        {% elif health.state.value == 'paused' %}
+            This connection is paused.
+        {% else %}
+            The runner isn't healthy right now{% if health.last_connected_at %} — last connected <time class="localtime-secs" datetime="{{ health.last_connected_at.isoformat() }}">{{ health.last_connected_at.strftime('%H:%M:%S UTC') }}</time>{% endif %}.
+        {% endif %}
+        Reissue a fresh setup message and paste it to the runner to bring it back.
+    </p>
+    <form method="post" action="/me/connections/{{ connection.id }}/reissue">
+        <button type="submit">Reissue &amp; show setup message</button>
+    </form>
+</div>
diff --git a/app/templates/connections/_status.html b/app/templates/connections/_status.html
new file mode 100644
