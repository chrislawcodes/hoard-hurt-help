      {
        "question": "Where do regular users create matches \u2014 a new user-facing flow, or by opening up the existing game-admin form?",
        "recommendation": "New user-facing create-match action on the game pages, reusing the existing creation logic server-side.",
        "rationale": "The admin form exposes admin-only knobs; a slim user flow keeps the admin surface unchanged.",
        "updated_at": 1781214266
      }
    ],
    "assumptions": [
      "users gains a role column ('admin' | 'user'); admin is seeded/synced at login from PLATFORM_ADMIN_EMAILS, which remains the bootstrap source.",
      "matches gains a nullable created_by_user_id; existing matches have no owner and are admin-managed only.",
      "Owner cancel of a running match is allowed (cancel preserves data); owner delete is pre-start only.",
      "Per-user active-match cap defaults to 3 and is configurable via an env var; admins are exempt.",
      "Match/leaderboard viewing stays public; agent and connection ownership rules are unchanged."
    ],
    "summary": "Two roles (admin/user) on the users table seeded from the existing platform-admin allowlist; match ownership via created_by_user_id; owner create/cancel anytime + delete pre-start; admin delete/cancel anything; per-user active-match cap.",
    "updated_at": 1781214307,
    "answers": {
      "Where do regular users create matches \u2014 a new user-facing flow, or by opening up the existing game-admin form?": "New user-facing create-match flow on the game pages, reusing existing server-side creation logic; admin form unchanged.",
      "When can a match owner delete their own match, given other users' players and scores live in it?": "Owner can delete only matches that have not started; admins can delete any match in any state."
    },
    "non_goals": [
      "No permissions tables, role hierarchies, or admin-management UI.",
      "No change to viewing: matches and leaderboards stay publicly readable.",
      "No change to the per-game admin (GAME_ADMIN_EMAILS) mechanism or the admin web forms.",
      "No soft-delete/archive system; no tournaments or leagues."
    ],
    "acceptance_criteria": [
      "A signed-in regular user can create a match from a user-facing game-page flow; the match records them as creator.",
      "A regular user can delete their own match only while it is pre-start, and can cancel their own running match; both are rejected for matches they do not own.",
      "An admin can delete or cancel any match in any state.",
      "A regular user cannot exceed the active-match cap; admins are exempt.",
      "Users whose email is in PLATFORM_ADMIN_EMAILS get role=admin on login; everyone else is role=user."
    ],
    "checklist": {
      "goal": "Introduce admin vs regular user roles: signed-in regular users can create matches and delete/cancel their own; admins can delete or cancel any match.",
      "audience": "Signed-in players of Hoard Hurt Help (regular users) and platform operators (admins).",
      "constraints": "Async app (async routes + async DB). Schema change needs an Alembic migration that works on SQLite and Postgres. Admin role seeded from existing PLATFORM_ADMIN_EMAILS allowlist. Per-user active-match cap to bound LLM spend. Game-admin email mechanism (GAME_ADMIN_EMAILS__<GAME>) stays as-is."
    },
