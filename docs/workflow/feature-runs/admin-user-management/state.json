    "questions": [
      {
        "question": "When an admin disables a user, what happens beyond blocking future logins?",
        "recommendation": "Login block only",
        "rationale": "Keeps scope in the admin + auth layer; disabled user can't sign in and their current session is rejected on next request. Connections/agents left as-is in DB but inert because owner can't act. No reach into connection runners or match scheduling.",
        "updated_at": 1781243394
      },
      {
        "question": "What admin-on-admin guardrails prevent lockout/escalation accidents?",
        "recommendation": "Config admins (PLATFORM_ADMIN_EMAILS) are an immutable floor",
        "rationale": "Admins seeded from the bootstrap email list cannot be demoted or disabled in-app. Because at least one config admin always exists, this also prevents a zero-admin lockout and self-lockout. DB-promoted admins remain fully mutable. Edge case: bootstrap list must be non-empty.",
        "updated_at": 1781243394
      },
      {
        "question": "Do we record an audit trail of admin actions?",
        "recommendation": "Yes \u2014 persistent audit log scoped to admin user-management actions",
        "rationale": "Record actor, target, action, timestamp, optional reason for disable/enable, promote/demote, and handle reset. Viewable in admin UI. Not platform-wide auditing (no game moves/API polls). Persistent table chosen over log-lines because these are privilege changes worth querying in-product later.",
        "updated_at": 1781243394
      }
    ],
    "assumptions": [],
    "summary": "",
    "updated_at": 1781243407,
    "answers": {},
    "non_goals": [
      "Hard-deleting users or cascade-deleting their connections/agents/match history (disable only).",
      "Halting running connection runners or pulling agents from active/queued matches when disabled (login block only).",
      "Hiding a disabled user's agents from public leaderboards/standings.",
      "Platform-wide audit logging of non-admin actions (game moves, API polls, normal logins).",
      "Removing PLATFORM_ADMIN_EMAILS; it stays as the immutable bootstrap floor.",
      "Changes to game-admin scope or game_admin routes (separate from platform-admin user management)."
    ],
    "acceptance_criteria": [
      "A platform admin can open /admin/users and see a searchable, paginated list of all users (email, handle, signup date, agent count, admin status, disabled status).",
      "A platform admin can open /admin/users/{id} and see that user's connections, agents, and recent match participation.",
      "A platform admin can disable an active user; that user is then rejected at login and on their next authenticated request (303 to a 'disabled' notice), without their data being deleted.",
      "A platform admin can re-enable a disabled user, restoring normal access.",
      "A platform admin can promote a non-admin user to platform admin and demote a DB-promoted admin; the change takes effect on their next request.",
      "A user seeded from PLATFORM_ADMIN_EMAILS cannot be demoted or disabled in-app (returns a clear error).",
      "Every disable/enable/promote/demote/handle-reset action writes an audit-log row (actor, target, action, timestamp, optional reason) visible in the admin UI.",
      "All user-management endpoints are gated by require_platform_admin; a non-admin hitting them directly gets 403.",
      "Alembic migration applies cleanly on the SQLite test DB (batch mode) and pytest/ruff/mypy pass."
    ],
    "checklist": {
      "goal": "Give platform admins an in-app way to manage users: view/search all users, disable (not delete) a user with login-time enforcement, and promote/demote other platform admins via a real DB role column. Email-config (PLATFORM_ADMIN_EMAILS) becomes the immutable bootstrap floor; in-app promotion layers DB-backed admins on top. All admin user-management actions are recorded to a persistent audit log.",
      "audience": "Platform admins (Chris-as-operator and any future co-admins). Indirectly: regular users, who can be disabled or have their handle reset.",
      "constraints": "Builds on the shipped admin-role-split (require_platform_admin email-based). Privilege-escalation surface: promote/demote and disable endpoints must be hard-gated to platform admins and tested against direct access. Disable must be enforced at session/auth layer, not just hidden in UI. Needs an Alembic migration (SQLite batch-mode safe). Bootstrap list PLATFORM_ADMIN_EMAILS must be non-empty or there is no immutable admin floor."
    },
    "unresolved": []
  },
