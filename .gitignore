# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
.python-version

# Environment / secrets
.env
.env.*
!.env.example
*.pem

# Database (local SQLite)
*.db
*.db-journal
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Migrations runtime
alembic/versions/__pycache__/

# Misc
*.bak
*.tmp

# Local SQLite backups (timestamped; *.bak above does not match these)
*.db.bak-*

# Agent / CLI runtime scratch (Codex CLI, agent harnesses) — never committed.
# These trip the Feature Factory's dirty-path check if not ignored.
.agents/
.codex/

# Agent / AI workspace dirs (local-only, never committed)
.claude/

# Database backup variants with non-.bak suffixes
*.db.*-bak
*.db.pre*-bak
*.db.stale*
*.db.tmp-*
*.db.empty-bak

# Feature Factory per-slug run locks (flock files, auto-released on crash —
# never committed; they otherwise trip implement's "working tree must be clean").
docs/workflow/feature-runs/*/.*.lock
# Feature Factory shared review-attempts log (auto-generated, not per-feature)
docs/workflow/operations/review-attempts.jsonl
