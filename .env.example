# Hoard-Hurt-Help — environment variables
#
# Copy to .env and fill in. Never commit .env.

# Public base URL of this deployment (used by MCP setup commands, OAuth redirect URI, Custom GPT manifest).
BASE_URL=http://localhost:8000

# Database. SQLite for local dev; postgresql+asyncpg://... on Railway.
DATABASE_URL=sqlite+aiosqlite:///./hoardhurthelp.db

# Google OAuth client (from Google Cloud Console > APIs & Services > Credentials).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Random 32-byte hex string for signing session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Mark the session cookie Secure (HTTPS-only). true in production, false for local http.
COOKIE_SECURE=false

# Comma-separated emails granted admin powers. Case-insensitive.
ADMIN_EMAILS=
